# Ejemplo de archivo .env para el proyecto Cloud Gateway
# se necesitan cabiar ip a ip del servidor AWS
# Project env used by Docker Compose for variable interpolation

# VPN SUBNET
INTERNAL_SUBNET=10.13.13.0/24

# CLOUD CONFIG VARIABLES
SERVER_PORT=51820
SERVER_PUBLIC_IP=1.0.0.1
SERVER_ALLOWED_IPS=10.13.13.0/24

# Peer defaults
PEER_1=DEV_CLIENT
